generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────

enum RoleName {
  ADMINISTRATOR
  DIRECTOR
  SALES_MANAGER
  PRICING_ANALYST
}

enum AssignmentRole {
  OWNER
  MANAGER
  ANALYST
  VIEWER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum ShippingTerms {
  PREPAID
  COLLECT
}

enum AllocationType {
  PERCENT_OF_SELLING_PRICE
  PERCENT_OF_NET_REVENUE
  PERCENT_OF_COST
  FIXED_PER_UNIT
  FIXED_PER_ORDER
  FIXED_PER_SHIPMENT
  FIXED_PER_SKU
  CUSTOM
}

enum AlertStatus {
  OK
  WARNING
  HIGH
  CRITICAL
}

enum ReviewStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  ESCALATED
}

enum MarginMethod {
  CONTRIBUTION_MARGIN
  GROSS_MARGIN
}

enum ImportStatus {
  PENDING
  VALIDATING
  PROCESSING
  COMPLETE
  FAILED
}

enum ImportRowStatus {
  PENDING
  SUCCESS
  ERROR
  SKIPPED
}

// ────────────────────────────────────────
// AUTHORIZATION
// ────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  description String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model UserPermission {
  userId       String
  permissionId String
  grantedBy    String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([userId, permissionId])
}

// ────────────────────────────────────────
// USERS
// ────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  roleId            String
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  failedLoginCount  Int       @default(0)
  lockedUntil       DateTime?
  mustResetPassword Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  role            Role               @relation(fields: [roleId], references: [id])
  userPermissions UserPermission[]
  assignments     CustomerAssignment[] @relation("AssignedUser")
  assignedBy      CustomerAssignment[] @relation("AssignedBy")
  auditLogs       AuditLog[]
  assignedSkus    CustomerSku[]       @relation("AssignedAnalyst")
  costHistoryRecorded ProductCostHistory[]
  priceHistoryRecorded CustomerPriceHistory[]
  importBatches   ImportBatch[]
}

// ────────────────────────────────────────
// PAYMENT TERMS
// ────────────────────────────────────────

model PaymentTerm {
  id          String   @id @default(uuid())
  name        String   @unique
  days        Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers Customer[]
}

// ────────────────────────────────────────
// CUSTOMERS
// ────────────────────────────────────────

model Customer {
  id                           String         @id @default(uuid())
  name                         String
  code                         String         @unique
  status                       CustomerStatus @default(ACTIVE)
  description                  String?
  currency                     String         @default("USD")
  timezone                     String         @default("America/New_York")
  shippingTerms                ShippingTerms  @default(PREPAID)
  defaultOriginPostalCode      String?
  defaultDestinationPostalCode String?
  isResidential                Boolean        @default(false)
  paymentTermId                String?
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  deletedAt                    DateTime?

  paymentTerm       PaymentTerm?              @relation(fields: [paymentTermId], references: [id])
  assignments       CustomerAssignment[]
  contacts          CustomerContact[]
  allocations       CustomerAllocation[]
  marginRequirement CustomerMarginRequirement?
  skus              CustomerSku[]
}

model CustomerAssignment {
  id           String         @id @default(uuid())
  userId       String
  customerId   String
  assignedById String
  role         AssignmentRole @default(ANALYST)
  createdAt    DateTime       @default(now())

  user       User     @relation("AssignedUser", fields: [userId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])
  assignedBy User     @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([userId, customerId])
}

model CustomerContact {
  id         String   @id @default(uuid())
  customerId String
  name       String
  title      String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
}

model CustomerAllocation {
  id                 String         @id @default(uuid())
  customerId         String
  name               String
  description        String?
  calculationType    AllocationType
  rate               Decimal?       @db.Decimal(10, 4)
  amount             Decimal?       @db.Decimal(19, 4)
  priority           Int            @default(0)
  isActive           Boolean        @default(true)
  isIncludedInMargin Boolean        @default(true)
  effectiveDate      DateTime       @db.Date
  expirationDate     DateTime?      @db.Date
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, isActive])
}

model CustomerMarginRequirement {
  id                       String       @id @default(uuid())
  customerId               String       @unique
  minimumMarginPercent     Decimal      @db.Decimal(10, 4)
  warningThresholdPercent  Decimal      @db.Decimal(10, 4)
  criticalThresholdPercent Decimal      @db.Decimal(10, 4)
  calculationMethod        MarginMethod @default(CONTRIBUTION_MARGIN)
  notes                    String?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
}

// ────────────────────────────────────────
// PRODUCTS
// ────────────────────────────────────────

model ProductCategory {
  id             String   @id @default(uuid())
  name           String
  parentId       String?
  dunnagePercent Decimal  @default(0) @db.Decimal(10, 4)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parent   ProductCategory?  @relation("CategoryParent", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryParent")
  products Product[]
}

model Product {
  id          String   @id @default(uuid())
  sku         String   @unique
  name        String
  brand       String?
  upc         String?
  categoryId  String?
  description String?
  unitOfMeasure String?
  isActive    Boolean  @default(true)

  // UPC / retail unit dimensions (inches, lbs)
  length  Decimal? @db.Decimal(10, 4)
  width   Decimal? @db.Decimal(10, 4)
  height  Decimal? @db.Decimal(10, 4)
  weight  Decimal? @db.Decimal(10, 4)

  // Shipping / case dimensions (used for carrier rate requests)
  shippingLength Decimal? @db.Decimal(10, 4)
  shippingWidth  Decimal? @db.Decimal(10, 4)
  shippingHeight Decimal? @db.Decimal(10, 4)
  shippingWeight Decimal? @db.Decimal(10, 4)

  // Confidential cost fields — stripped by stripCostFields() for users without view_product_cost
  currentCost              Decimal?  @db.Decimal(19, 4)
  futureCost               Decimal?  @db.Decimal(19, 4)
  costEffectiveDate        DateTime? @db.Date
  futureCostEffectiveDate  DateTime? @db.Date
  costSource               String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  category    ProductCategory?    @relation(fields: [categoryId], references: [id])
  costHistory ProductCostHistory[]
  customerSkus CustomerSku[]
}

// Append-only — no updatedAt, no deletedAt
model ProductCostHistory {
  id            String   @id @default(uuid())
  productId     String
  cost          Decimal  @db.Decimal(19, 4)
  effectiveDate DateTime @db.Date
  source        String?
  recordedById  String
  createdAt     DateTime @default(now())

  product    Product @relation(fields: [productId], references: [id])
  recordedBy User    @relation(fields: [recordedById], references: [id])

  @@index([productId, createdAt])
}

// ────────────────────────────────────────
// CUSTOMER-SKU (central analysis entity)
// ────────────────────────────────────────

model CustomerSku {
  id                    String        @id @default(uuid())
  customerId            String
  productId             String
  customerSkuCode       String?
  sellingPrice          Decimal?      @db.Decimal(19, 4)
  packageQuantity       Int           @default(1)
  minimumMarginOverride Decimal?      @db.Decimal(10, 4)
  shippingTermsOverride ShippingTerms?
  useShippingDimensions Boolean       @default(false)
  alertStatus           AlertStatus   @default(OK)
  reviewStatus          ReviewStatus  @default(PENDING)
  assignedAnalystId     String?
  lastCalculatedAt      DateTime?
  lastQuotedAt          DateTime?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  deletedAt             DateTime?

  customer       Customer               @relation(fields: [customerId], references: [id])
  product        Product                @relation(fields: [productId], references: [id])
  assignedAnalyst User?                 @relation("AssignedAnalyst", fields: [assignedAnalystId], references: [id])
  priceHistory   CustomerPriceHistory[]

  @@unique([customerId, productId])
  @@index([customerId, alertStatus])
}

// Append-only
model CustomerPriceHistory {
  id            String   @id @default(uuid())
  customerSkuId String
  sellingPrice  Decimal  @db.Decimal(19, 4)
  effectiveDate DateTime @db.Date
  recordedById  String
  createdAt     DateTime @default(now())

  customerSku CustomerSku @relation(fields: [customerSkuId], references: [id])
  recordedBy  User        @relation(fields: [recordedById], references: [id])

  @@index([customerSkuId, createdAt])
}

// ────────────────────────────────────────
// IMPORTS
// ────────────────────────────────────────

model ImportBatch {
  id           String       @id @default(uuid())
  uploadedById String
  customerId   String?
  filename     String
  status       ImportStatus @default(PENDING)
  totalRows    Int          @default(0)
  successRows  Int          @default(0)
  errorRows    Int          @default(0)
  skippedRows  Int          @default(0)
  errorSummary Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  uploadedBy User         @relation(fields: [uploadedById], references: [id])
  rows       ImportRow[]

  @@index([uploadedById, createdAt])
}

model ImportRow {
  id        String          @id @default(uuid())
  batchId   String
  rowNumber Int
  rawData   Json
  status    ImportRowStatus @default(PENDING)
  errors    Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  batch ImportBatch @relation(fields: [batchId], references: [id])

  @@index([batchId, status])
}

// ────────────────────────────────────────
// AUDIT LOG (append-only)
// ────────────────────────────────────────

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  action        String
  entityType    String
  entityId      String
  beforeValue   Json?
  afterValue    Json?
  sourceIp      String?
  correlationId String?
  importBatchId String?
  jobId         String?
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
