# Database
DATABASE_URL="postgresql://sympl:symplpass@localhost:5432/sympl_pas"
DATABASE_TEST_URL="postgresql://sympl:symplpass@localhost:5432/sympl_pas_test"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Encryption key for secrets stored in SystemConfig (32-byte hex)
APP_ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# UPS API (configured via Admin UI - credentials stored encrypted in DB)
# UPS_CLIENT_ID=""
# UPS_CLIENT_SECRET=""
# UPS_ACCOUNT_NUMBER=""

# USPS API (configured via Admin UI - credentials stored encrypted in DB)
# USPS_USER_ID=""

# SMTP (configured via Admin UI - credentials stored encrypted in DB)
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
